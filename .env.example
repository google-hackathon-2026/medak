# Vertex AI
GOOGLE_API_KEY=your-vertex-ai-api-key   # GCP API key bound to service account
GOOGLE_CLOUD_PROJECT=proud-quasar-310818
GOOGLE_CLOUD_LOCATION=us-central1

# Redis
REDIS_URL=redis://localhost:6379

# Twilio (leave blank to skip real calls, use mock mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Demo target phone (NEVER use real 112 or 194)
EMERGENCY_NUMBER=+381601234567

# Public URL for Twilio callbacks (use ngrok for local dev)
BACKEND_BASE_URL=https://your-cloud-run-url

# Tuning
TRIAGE_TIMEOUT_SECONDS=10
CONFIDENCE_THRESHOLD=0.85
RECONNECT_MAX_ATTEMPTS=3
